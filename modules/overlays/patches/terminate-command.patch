+/// `simctl terminate` reports failure when the app is not running; that is the
+/// requested end state, so it is not surfaced as an error.
+pub fn terminate_bundle(udid: &str, bundle_id: &str) -> Result<(), crate::error::AppError> {
+    let output = Command::new("/usr/bin/xcrun")
+        .args(["simctl", "terminate", udid, bundle_id])
+        .output()
+        .map_err(|error| {
+            crate::error::AppError::native(format!("Unable to run simctl terminate. {error}"))
+        })?;
+    if output.status.success() {
+        return Ok(());
+    }
+    let stderr = String::from_utf8_lossy(&output.stderr);
+    if stderr.contains("found nothing to terminate") || stderr.contains("not currently running") {
+        return Ok(());
+    }
+    Err(crate::error::AppError::native(format!(
+        "simctl terminate failed. {}",
+        stderr.trim()
+    )))
+}
