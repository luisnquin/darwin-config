+    fn resolve_launcher_component(&self, serial: &str, package: &str) -> Option<String> {
+        let output = self
+            .run_adb_shell(
+                serial,
+                &format!(
+                    "cmd package resolve-activity --brief -a android.intent.action.MAIN \
+                     -c android.intent.category.LAUNCHER {}",
+                    shell_quote(package)
+                ),
+            )
+            .ok()?;
+        output
+            .lines()
+            .rev()
+            .map(str::trim)
+            .find(|line| is_android_component_name(line))
+            .map(str::to_owned)
+    }
