+/// Positional target of a batch `tap` step, following the same grammar the
+/// top-level `tap` command implements in `parse_tap_command_args`.
+enum BatchTapPositional {
+    None,
+    Point { x: f64, y: f64 },
+    Index(usize),
+    Label(String),
+}
+
+fn batch_tap_positional(args: &StepOptions) -> Result<BatchTapPositional, crate::error::AppError> {
+    let tokens = args
+        .positionals
+        .iter()
+        .map(|token| token.trim())
+        .filter(|token| !token.is_empty())
+        .collect::<Vec<_>>();
+
+    if tokens.is_empty() {
+        return Ok(BatchTapPositional::None);
+    }
+
+    if tokens.len() == 2 {
+        if let (Some(x), Some(y)) = (parse_f64_arg(tokens[0]), parse_f64_arg(tokens[1])) {
+            return Ok(BatchTapPositional::Point { x, y });
+        }
+    }
+
+    if tokens.len() == 1 && parse_f64_arg(tokens[0]).is_some() {
+        return Err(crate::error::AppError::bad_request(
+            "tap requires both x and y coordinates.",
+        ));
+    }
+
+    if tokens.iter().any(|token| parse_f64_arg(token).is_some()) {
+        return Err(crate::error::AppError::bad_request(
+            "tap coordinates must be provided as exactly two numeric values.",
+        ));
+    }
+
+    if tokens.len() == 1 {
+        if let Some(index) = parse_agent_ref(tokens[0]) {
+            return Ok(BatchTapPositional::Index(index));
+        }
+    }
+
+    Ok(BatchTapPositional::Label(tokens.join(" ")))
+}
+
 fn required_f64(args: &StepOptions, key: &str) -> Result<f64, crate::error::AppError> {
     args.value(key)
         .ok_or_else(|| crate::error::AppError::bad_request(format!("Missing --{key}.")))?
